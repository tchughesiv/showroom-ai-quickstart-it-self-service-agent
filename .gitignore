# Ignore macOS system files
.DS_Store

# Local Python venv and vendored Vale (make install)
.venv/
.tools/

# Ignore node_modules directory
node_modules/

# Ignore build output
www/
.cache/

# Vale package styles from `vale sync` (not committed; recreated by make install / vale sync)
.vale/styles/packages/
.vale/styles/write-good/

# Ignore IDE and editor files
.vscode/
.idea/

# Ignore logs and temporary files
*.log
*.tmp

# Ignore environment-specific files
.env
.env.local
.env.*.local

# Ignore sensitive or private information
secrets.json

# Ignore compiled binaries or executables
*.exe
*.dll
*.so
*.dylib
*.core

# Ignore yarn.lock for Yarn
yarn.lock
