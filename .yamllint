# https://yamllint.readthedocs.io/en/stable/configuration.html
extends: default

ignore: |
  .github/

rules:
  document-start: disable
  line-length:
    max: 200
    allow-non-breakable-words: true
  comments:
    min-spaces-from-content: 1
  brackets:
    max-spaces-inside: 1
  truthy:
    # GitHub Actions keys like `on:` are not booleans
    check-keys: false
